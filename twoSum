class Solution {
    public int[] twoSum(int[] arr, int target) {
        int n = arr.length;
        int i = 0;

        while (i < n) {
            int j = i + 1;

            while (j < n) {
                if (arr[i] + arr[j] == target) {
                    return new int[]{i, j};
                }
                j++;
            }

            i++;
        }

        return new int[]{};
    }
}
